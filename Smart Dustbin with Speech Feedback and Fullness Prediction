#include <Servo.h>
#include <SoftwareSerial.h>

const int IR_SENSOR_PIN = 2;
const int ECHO_PIN = 6;
const int TRIG_PIN = 7;
const int SERVO_PIN = 9;
const int MP3_RX_PIN = 10;
const int MP3_TX_PIN = 11;

const int LID_OPEN_ANGLE = 90;
const int LID_CLOSED_ANGLE = 0;

const unsigned long LID_OPEN_MS = 2000;
const unsigned long TRIGGER_COOLDOWN_MS = 2500;

Servo lid;
SoftwareSerial mp3(MP3_RX_PIN, MP3_TX_PIN); // DFPlayer Mini

unsigned long lastTriggerTime = 0;

void sendDFPlayerCommand(uint8_t command, uint16_t argument) {
  // 10-byte DFPlayer frame with checksum.
  uint8_t packet[10] = {
    0x7E, 0xFF, 0x06, command, 0x00,
    (uint8_t)(argument >> 8),
    (uint8_t)(argument & 0xFF),
    0x00, 0x00,
    0xEF
  };

  uint16_t checksum = 0;
  for (int i = 1; i < 7; i++) checksum += packet[i];
  checksum = 0 - checksum;
  packet[7] = (uint8_t)(checksum >> 8);
  packet[8] = (uint8_t)(checksum & 0xFF);

  for (int i = 0; i < 10; i++) {
    mp3.write(packet[i]);
  }

  delay(100);
}

void speakTrack(uint16_t trackNumber) {
  // Command 0x03 = play track by index.
  sendDFPlayerCommand(0x03, trackNumber);
}

void setVolume(uint8_t level) {
  if (level > 30) level = 30;
  sendDFPlayerCommand(0x06, level);
}

void openLid() {
  lid.write(LID_OPEN_ANGLE);
}

void closeLid() {
  lid.write(LID_CLOSED_ANGLE);
}

int getTrashLevelPercent() {
  digitalWrite(TRIG_PIN, LOW);
  delayMicroseconds(2);
  digitalWrite(TRIG_PIN, HIGH);
  delayMicroseconds(10);
  digitalWrite(TRIG_PIN, LOW);

  long duration = pulseIn(ECHO_PIN, HIGH, 30000); // Timeout ~5m range.
  if (duration == 0) return -1;

  int distanceCm = duration * 0.034 / 2;
  // Tune 10..30 cm according to your bin geometry.
  int level = map(distanceCm, 30, 10, 0, 100);
  return constrain(level, 0, 100);
}

bool objectDetected() {
  // Common IR obstacle sensors are active LOW.
  return digitalRead(IR_SENSOR_PIN) == LOW;
}

void setup() {
  pinMode(IR_SENSOR_PIN, INPUT);
  pinMode(TRIG_PIN, OUTPUT);
  pinMode(ECHO_PIN, INPUT);

  Serial.begin(9600);
  mp3.begin(9600);

  lid.attach(SERVO_PIN);
  closeLid();

  delay(500);
  setVolume(22);
  speakTrack(1); // Welcome message
}

void loop() {
  unsigned long now = millis();

  if (!objectDetected()) {
    delay(60);
    return;
  }

  if (now - lastTriggerTime < TRIGGER_COOLDOWN_MS) {
    delay(60);
    return;
  }

  lastTriggerTime = now;

  openLid();
  delay(LID_OPEN_MS);
  closeLid();

  int level = getTrashLevelPercent();
  Serial.print("Fill level (%): ");
  Serial.println(level);

  if (level >= 70) {
    speakTrack(2); // Almost full
  } else {
    speakTrack(3); // Thank you
  }

  delay(200);
}
