const int IR_LEFT_PIN = 2;
const int IR_RIGHT_PIN = 3;

const int MOTOR_LEFT_IN1 = 4;
const int MOTOR_LEFT_IN2 = 5;
const int MOTOR_RIGHT_IN1 = 6;
const int MOTOR_RIGHT_IN2 = 7;

const int ENA = 9;
const int ENB = 10;

const int SPEED_FORWARD = 185;
const int SPEED_TURN_FAST = 185;
const int SPEED_TURN_SLOW = 95;

void setMotorDirectionForward() {
  digitalWrite(MOTOR_LEFT_IN1, HIGH);
  digitalWrite(MOTOR_LEFT_IN2, LOW);
  digitalWrite(MOTOR_RIGHT_IN1, HIGH);
  digitalWrite(MOTOR_RIGHT_IN2, LOW);
}

void setMotorSpeed(int leftSpeed, int rightSpeed) {
  analogWrite(ENA, constrain(leftSpeed, 0, 255));
  analogWrite(ENB, constrain(rightSpeed, 0, 255));
}

void stopMotors() {
  digitalWrite(MOTOR_LEFT_IN1, LOW);
  digitalWrite(MOTOR_LEFT_IN2, LOW);
  digitalWrite(MOTOR_RIGHT_IN1, LOW);
  digitalWrite(MOTOR_RIGHT_IN2, LOW);
  setMotorSpeed(0, 0);
}

void setup() {
  pinMode(IR_LEFT_PIN, INPUT);
  pinMode(IR_RIGHT_PIN, INPUT);

  pinMode(MOTOR_LEFT_IN1, OUTPUT);
  pinMode(MOTOR_LEFT_IN2, OUTPUT);
  pinMode(MOTOR_RIGHT_IN1, OUTPUT);
  pinMode(MOTOR_RIGHT_IN2, OUTPUT);

  pinMode(ENA, OUTPUT);
  pinMode(ENB, OUTPUT);

  Serial.begin(9600);
}

void loop() {
  int leftSensor = digitalRead(IR_LEFT_PIN);
  int rightSensor = digitalRead(IR_RIGHT_PIN);

  // Typical IR modules: LOW = line detected, HIGH = no line.
  if (leftSensor == LOW && rightSensor == LOW) {
    setMotorDirectionForward();
    setMotorSpeed(SPEED_FORWARD, SPEED_FORWARD);
    Serial.println("FORWARD");
  } else if (leftSensor == HIGH && rightSensor == LOW) {
    // Robot drifted left of track -> steer right.
    setMotorDirectionForward();
    setMotorSpeed(SPEED_TURN_FAST, SPEED_TURN_SLOW);
    Serial.println("RIGHT");
  } else if (leftSensor == LOW && rightSensor == HIGH) {
    // Robot drifted right of track -> steer left.
    setMotorDirectionForward();
    setMotorSpeed(SPEED_TURN_SLOW, SPEED_TURN_FAST);
    Serial.println("LEFT");
  } else {
    // Line is lost by both sensors.
    stopMotors();
    Serial.println("STOP/LOST");
  }

  delay(50);
}
